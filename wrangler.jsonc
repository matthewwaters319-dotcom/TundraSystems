{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tundrasystems",
  "main": "src/worker.js",
  "account_id": "8f82b7dfd7ba350ba44d6b808e13d58b",
  "compatibility_date": "2026-05-08",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "kv_namespaces": [
    {
      "binding": "TUNDRA_CLAIMS",
      "id": "43f003de6b4149ed934cf69a33df631a"
    }
  ]
}
